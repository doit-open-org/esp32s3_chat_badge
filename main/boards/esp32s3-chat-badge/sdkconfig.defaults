# Board selection and language resources
CONFIG_BOARD_PATH="esp32s3-chat-badge"
CONFIG_ASSETS_FIX_PATH="assets_overrides"
CONFIG_LANGUAGE_ZH_CN=y

# Wi-Fi provisioning
CONFIG_USE_SOFTAP_NET_CONFIGURING=y
CONFIG_WIFI_CONFIG_MODE_FORMAT_DISPLAY=y
CONFIG_WIFI_CONFIG_MODE_SSID_PREFIX="MZ"

# The VB6824 performs the wake-word/audio front-end work on this board.
# CONFIG_USE_AFE_WAKE_WORD is not set
# CONFIG_USE_CUSTOM_WAKE_WORD is not set
# CONFIG_USE_AUDIO_PROCESSOR is not set
CONFIG_USE_DEVICE_AEC=y
# CONFIG_USE_SERVER_AEC is not set

CONFIG_SPEAKING_FIRST_MUTE_TIME=60

# UI codecs used by the badge interface
CONFIG_LV_USE_GIF=y
CONFIG_LV_GIF_CACHE_DECODE_DATA=y
CONFIG_LV_USE_QOIF=y

# Keep legacy DOIT OTA behavior; change the endpoint in menuconfig for production.
CONFIG_USE_CUSTOM_OTA=y

# ESP32-S3 octal PSRAM tuning used by the production firmware
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MALLOC_RESERVE_INTERNAL=47536
CONFIG_SPIRAM_ALLOW_BSS_SEG_EXTERNAL_MEMORY=y
CONFIG_SPIRAM_ALLOW_NOINIT_SEG_EXTERNAL_MEMORY=y
CONFIG_SPIRAM_TRY_ALLOCATE_WIFI_LWIP=y
CONFIG_SPIRAM_XIP_FROM_PSRAM=y
CONFIG_SPIRAM_MALLOC_ALWAYSINTERNAL=0

CONFIG_ESP_WIFI_STATIC_RX_BUFFER_NUM=8
CONFIG_ESP_WIFI_DYNAMIC_RX_BUFFER_NUM=8
CONFIG_ESP_WIFI_RX_BA_WIN=8
CONFIG_ESP_WIFI_TX_BA_WIN=8

# VB6824 supplies 40-byte Opus frames directly.
CONFIG_USE_AUDIO_CODEC_ENCODE_OPUS=y
# CONFIG_USE_AUDIO_CODEC_DECODE_OPUS is not set

# Mini-program material packages stored on microSD
CONFIG_SUPPORT_MINI_PROGRAMS_REPLACE_PSD=y
CONFIG_USE_PSD_MULTIPLE=y
CONFIG_USE_PSD_MULTIPLE_NUM=3
CONFIG_USE_PSD_MULTIPLE_FILE_FIRST="vpg_first"
CONFIG_USE_PSD_MULTIPLE_FILE_SECOND="vpg_second"
CONFIG_USE_PSD_MULTIPLE_FILE_THIRD="vpg_third"
